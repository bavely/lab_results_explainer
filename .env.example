# Copy this file to apps/api/.env for local development.
PORT=4000
NODE_ENV=development

# Choose one: openai, azure_foundry_agent, or mock.
AI_PROVIDER=openai
OPENAI_API_KEY=
# Optional: set for Azure/OpenRouter/custom-compatible endpoints.
# Example Azure value: https://<resource>.openai.azure.com/openai/v1/
OPENAI_BASE_URL=
# Model/deployment to use when calling the OpenAI-compatible endpoint.
# For OpenAI API this is a model (e.g. gpt-4.1-mini). For Azure this is your deployment name.
OPENAI_MODEL=
# Backward-compatible fallback if OPENAI_MODEL is not set.
# Azure OpenAI: must match the deployment name in Azure OpenAI Studio, not the base model name.
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# Azure AI Foundry agent settings (required when AI_PROVIDER=azure_foundry_agent)
AZURE_AI_PROJECT_ENDPOINT=
AZURE_AI_AGENT_NAME=
AZURE_AI_AGENT_VERSION=

# On AI provider failure: "fail" throws an error (fail closed), "allow" silently falls back to mock (fail open).
# Recommended: "fail" in production so failures surface immediately rather than serving degraded output.
AI_FALLBACK_POLICY=allow

MAX_UPLOAD_MB=10
DELETE_UPLOADS_AFTER_PARSE=true
CLIENT_ORIGIN=http://localhost:5173
